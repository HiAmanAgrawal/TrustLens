# TrustLens — copy this to .env and fill in real values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------
# App
# -----------------------------------------------------------------------
APP_ENV=development          # development | staging | production
APP_VERSION=0.2.0
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------
# Database — Supabase / PostgreSQL + pgvector
# -----------------------------------------------------------------------
# Async DSN used by FastAPI at runtime (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trustlens
# Sync DSN used by Alembic for migrations — leave empty to auto-derive from DATABASE_URL
DATABASE_URL_SYNC=

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------
# Redis — session / in-memory agent state
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600     # WhatsApp session memory TTL (1 hour)

# -----------------------------------------------------------------------
# WhatsApp — Twilio (pick Twilio OR Meta, not both)
# -----------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio Sandbox sender

# -----------------------------------------------------------------------
# WhatsApp — Meta Cloud API
# -----------------------------------------------------------------------
META_WABA_PHONE_ID=
META_WABA_TOKEN=
META_WABA_VERIFY_TOKEN=

# -----------------------------------------------------------------------
# WhatsApp — Unipile
# -----------------------------------------------------------------------
UNIPILE_API_KEY=
UNIPILE_DSN=

# -----------------------------------------------------------------------
# Google AI (Gemini Vision — primary OCR)
# Tesseract is the fallback when this key is absent or Gemini fails.
# Get one at https://aistudio.google.com/apikey
# -----------------------------------------------------------------------
GOOGLE_API_KEY=
GOOGLE_VISION_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------
# OpenAI — text embeddings for pgvector semantic search
# Can point at any OpenAI-compatible endpoint (local, Azure, Supabase).
# -----------------------------------------------------------------------
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------
# LangChain / LangGraph agent tracing
# -----------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trustlens

# -----------------------------------------------------------------------
# Tavily — web search for unknown products
# -----------------------------------------------------------------------
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# -----------------------------------------------------------------------
# Scraper
# -----------------------------------------------------------------------
CAPSOLVER_API_KEY=           # CAPTCHA bypass (optional, wired but not active)
SCRAPER_TIMEOUT_S=30.0

# -----------------------------------------------------------------------
# i18n — static catalogues
# -----------------------------------------------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=["en","hi","ta","mr"]

# -----------------------------------------------------------------------
# i18n — AI-powered translation  (USE_AI_I18N=true to enable)
#
# Safety-critical keys (verdicts, allergen warnings, drug interactions)
# always use static catalogues regardless of this flag.
# Conversational keys (WhatsApp replies, summaries) use AI when enabled.
#
# Provider options:
#   gemini   — Google Gemini (uses GOOGLE_API_KEY above)
#   lmstudio — any local OpenAI-compatible server (free, private, offline)
#   openai   — OpenAI cloud API
# -----------------------------------------------------------------------
USE_AI_I18N=false
I18N_AI_PROVIDER=gemini              # gemini | lmstudio | openai
I18N_AI_MODEL=gemini-2.0-flash-lite  # swap to your LM Studio model name if using lmstudio

# OpenAI-compatible base URL — only needed for lmstudio / openai provider
# LM Studio default:  http://localhost:1234/v1
# Ollama default:     http://localhost:11434/v1
# OpenAI cloud:       https://api.openai.com/v1  (already the default)
OPENAI_BASE_URL=https://api.openai.com/v1

# In-process LRU cache for AI translations (prevent duplicate API calls)
I18N_CACHE_SIZE=512

# -----------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------
ENABLE_LLM_SUMMARIES=false   # Gate LLM-generated verdict summaries (costs $)
ENABLE_WEB_SEARCH=true       # Tavily search for unknown barcodes
