# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- App ---
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- WhatsApp provider (pick one once decided) ---
# Twilio Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=          # e.g. whatsapp:+14155238886

# Meta WhatsApp Cloud API
META_WABA_PHONE_ID=
META_WABA_TOKEN=
META_WABA_VERIFY_TOKEN=        # for webhook verification handshake

# Unipile
UNIPILE_API_KEY=
UNIPILE_DSN=

# --- Scraper ---
CAPSOLVER_API_KEY=             # optional, only when bypassing CAPTCHAs

# --- LLM / Vision (used by services/ocr) ---
# Google ADK / Gemini key — fallback when local Tesseract OCR confidence is low.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_VISION_MODEL=gemini-2.5-flash    # override if you want a different vision model
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database (future) ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/trustlens
